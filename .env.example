# ─────────────────────────────────────────────
# Job Application Assistant Agent — Environment
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# Groq — free tier at console.groq.com
# Used for: resume parsing, JD analysis, resume tailoring,
#            cover letter writing, LinkedIn outreach
GROQ_API_KEY=gsk_your_key_here

# Tavily — free tier at tavily.com (1,000 searches/month)
# Used for: company research (4 searches per run)
TAVILY_API_KEY=tvly-your_key_here
